{
  "name": "lzxfrontend",
  "private": true,
  "sideEffects": false,
  "version": "0.2.1",
  "scripts": {
    "dev": "shopify hydrogen dev --codegen",
    "dev-legacy": "shopify hydrogen dev --codegen --legacy-runtime",
    "preview": "shopify hydrogen preview --build",
    "preview-legacy": "shopify hydrogen preview --build --legacy-runtime",
    "codegen": "shopify hydrogen codegen",
    "build": "shopify hydrogen build --codegen && yarn search:index",
    "lint": "eslint --no-error-on-unmatched-pattern --ignore-pattern 'lfs/**' --ext .js,.ts,.jsx,.tsx .",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari --project=tablet",
    "test:e2e:smoke": "playwright test smoke.spec.ts",
    "test:e2e:flows": "playwright test flows.spec.ts",
    "test:e2e:api": "playwright test api.spec.ts",
    "test:e2e:responsive": "playwright test responsive.spec.ts",
    "test:e2e:visual": "playwright test visual-regression.spec.ts",
    "test:e2e:visual:update": "playwright test visual-regression.spec.ts --update-snapshots",
    "test:e2e:all": "playwright test",
    "search:index": "node scripts/build-search-index.mjs"
  },
  "browserslist": [
    "defaults"
  ],
  "prettier": "@shopify/prettier-config",
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@headlessui/react": "^1.7.2",
    "@remix-run/react": "2.16.1",
    "@remix-run/server-runtime": "2.16.1",
    "@shopify/hydrogen": "2025.4.2",
    "@shopify/remix-oxygen": "2.1.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^1.2.1",
    "daisyui": "^2.51.6",
    "graphql": "^16.6.0",
    "gray-matter": "^4.0.3",
    "isbot": "^3.8.0",
    "less": "^4.2.1",
    "medium-zoom": "^1.1.0",
    "mermaid": "^11.14.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^4.8.0",
    "react-intersection-observer": "^9.4.1",
    "react-mailchimp-subscribe": "^2.1.3",
    "react-modal-image": "^2.6.0",
    "react-use": "^17.4.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remarkable": "^2.0.1",
    "schema-dts": "^1.1.0",
    "tiny-invariant": "^1.2.0",
    "typographic-base": "^1.0.4",
    "unified": "^11.0.5",
    "worktop": "^0.7.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@graphql-codegen/cli": "5.0.2",
    "@playwright/test": "^1.59.1",
    "@remix-run/dev": "2.16.1",
    "@remix-run/eslint-config": "2.16.1",
    "@shopify/cli": "3.61.2",
    "@shopify/cli-hydrogen": "8.1.1",
    "@shopify/hydrogen-codegen": "^0.3.3",
    "@shopify/mini-oxygen": "3.1.1",
    "@shopify/oxygen-workers-types": "4.1.2",
    "@shopify/prettier-config": "^1.1.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__preset-env": "^7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/react-mailchimp-subscribe": "^2.1.1",
    "@types/react-modal-image": "^2.6.0",
    "@types/remarkable": "^2.0.3",
    "@types/xml2js": "^0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.20.0",
    "eslint-plugin-hydrogen": "0.12.2",
    "eslint-plugin-import": "^2.31.0",
    "jsdom": "^29.0.2",
    "msw": "^2.13.0",
    "pagefind": "^1.4.0",
    "postcss": "^8.4.21",
    "postcss-preset-env": "^10.1.3",
    "prettier": "^2.8.4",
    "tailwindcss": "^3.3.0",
    "typescript": "5.2.2",
    "vite": "^5.1.0",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^1.6.0",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": ">=18.19"
  },
  "packageManager": "yarn@4.5.3",
  "type": "module"
}
